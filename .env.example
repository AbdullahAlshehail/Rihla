# ─────────────────────────────────────────────────────────
# Supabase (REQUIRED — get from https://app.supabase.com → Project Settings → API)
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# Server-only: used by seed scripts and admin operations. NEVER expose.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ─────────────────────────────────────────────────────────
# Google Cloud APIs (server-side ONLY — never exposed to browser)
# Enable: Places API (New), Routes API, Geocoding API
# ─────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─────────────────────────────────────────────────────────
# Groq (OPTIONAL) — Arabic AI summarization of Google reviews.
# Free tier is generous. Get a key: https://console.groq.com
# Without this key, raw Google review snippets are shown instead.
# ─────────────────────────────────────────────────────────
GROQ_API_KEY=

# ─────────────────────────────────────────────────────────
# Anthropic (REQUIRED for booking-extract + trending-scan)
# Uses Claude Sonnet 4.6 with web_search tool for trending detection.
# Get a key: https://console.anthropic.com
# ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────
# Cron secret — Authorization: Bearer <CRON_SECRET> on /api/cron/*
# Generate: openssl rand -hex 24
# ─────────────────────────────────────────────────────────
CRON_SECRET=

# ─────────────────────────────────────────────────────────
# Brave Search API (OPTIONAL but recommended for trending)
# Free tier: 2000 queries/month. Cuts trending-scan cost ~75%.
# Without this key, scan falls back to Anthropic's web_search tool ($0.01/q).
# Get a key: https://brave.com/search/api/
# ─────────────────────────────────────────────────────────
BRAVE_API_KEY=

# ─────────────────────────────────────────────────────────
# App config
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
